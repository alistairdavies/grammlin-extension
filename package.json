{
  "name": "Grammlin",
  "description": "Grammlin is a tool for Swedish language learners providing grammatical information and word definitions.",
  "private": true,
  "version": "1.5.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox --mv3",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox --mv3",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox --mv3",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "4.2.2",
    "@thedutchcoder/postcss-rem-to-px": "^0.0.2",
    "@tsconfig/svelte": "^5.0.5",
    "@wxt-dev/module-svelte": "^2.0.3",
    "daisyui": "^5.5.5",
    "msw": "^2.12.14",
    "postcss": "^8.5.10",
    "svelte": "^5.38.6",
    "svelte-check": "^4.3.1",
    "tailwindcss": "4.2.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.2",
    "vitest": "^4.1.5",
    "wxt": "^0.20.6"
  },
  "dependencies": {
    "@lucide/svelte": "^0.555.0",
    "openapi-fetch": "^0.15.0"
  }
}
